# Example environment variables for the React frontend
# Copy this to client/.env (do NOT commit secrets) and adjust values as needed

# API backend base URL used by the app at runtime/build-time
REACT_APP_API_URL=http://localhost:4000

# Optional third-party keys (examples)
REACT_APP_MAP_KEY=your_map_key_here
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
REACT_APP_SENTRY_DSN=

# Feature toggles
REACT_APP_ENABLE_FEATURE_X=false

# Example: include any other REACT_APP_* variables your app reads
# REACT_APP_CUSTOM=value
